# ===========================================
# RST Style Studio LK — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# ---- Database (Prisma v7 + @prisma/adapter-pg) ----
# Used by prisma.config.ts for migrations and by PrismaPg adapter at runtime
DATABASE_URL="postgresql://user:password@localhost:5432/rst_studio?schema=public"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ---- YouTube Data API v3 ----
YOUTUBE_API_KEY="your-youtube-api-key"
YOUTUBE_CHANNEL_ID="your-youtube-channel-id"

# ---- Spotify Web API (Client Credentials) ----
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_ARTIST_ID="your-spotify-artist-id"

# ---- Facebook Graph API ----
FACEBOOK_PAGE_ID="your-facebook-page-id"
FACEBOOK_ACCESS_TOKEN="your-facebook-page-access-token"

# ---- Vercel Cron Authentication ----
CRON_SECRET="your-random-cron-secret"

# ---- Email (Resend) ----
RESEND_API_KEY="your-resend-api-key"
